	<script>
	    // Данные должника (в реальном приложении будут загружаться с сервера)
	    let currentDebtor = {
	        id: {{ id }},
	        provider: "ОС",
	        fio: "Иванов Иван Иванович",
	        login: "ivanov.i",
	        status: "Активный",
	        comments: "Тестовый комментарий к должнику. Здесь может быть длинный текст, который будет переноситься на новую строку и при необходимости появится прокрутка, если текста будет очень много.",
	        connectionType: "LTE",
	        hasEquipment: false,
	        totalDebt: 150000,
	        collectedAmount: 45000,
	        remainDebt: 105000
	    };
	    
	    // Функция для обновления статистики
	    function updateStats() {
	        document.getElementById('total-debt').textContent = currentDebtor.totalDebt.toLocaleString() + ' ₽';
	        document.getElementById('collected-amount').textContent = currentDebtor.collectedAmount.toLocaleString() + ' ₽';
	        document.getElementById('remain-debt').textContent = currentDebtor.remainDebt.toLocaleString() + ' ₽';
	    }
	    
	    // Функция для отображения статуса с классом
	    function getStatusHtml(status) {
	        let statusClass = '';
	        if (status === 'Активный') statusClass = 'status-active';
	        else if (status === 'Неактивный') statusClass = 'status-inactive';
	        else if (status === 'Заблокирован') statusClass = 'status-blocked';
	        
	        return `<span class="${statusClass}">${status}</span>`;
	    }
	    
	    // Функция обновления активного состояния свитчера
	    function updateSwitchState(connectionType) {
	        const lteBtn = document.getElementById('switch-lte');
	        const ethernetBtn = document.getElementById('switch-ethernet');
	        
	        if (connectionType === 'LTE') {
	            lteBtn.classList.add('active');
	            ethernetBtn.classList.remove('active');
	        } else {
	            ethernetBtn.classList.add('active');
	            lteBtn.classList.remove('active');
	        }
	    }
	    
	    // Функция для управления доступом к таблицам (вкл/выкл кнопки)
	    function setTablesEditMode(enabled) {
	        // Получаем все кнопки управления таблицами
	        const deleteButtons = document.querySelectorAll('.btn-delete-selected');
	        const addButtons = document.querySelectorAll('.btn-add-row');
	        const attachFileBtn = document.getElementById('attach-file-btn');
	        
	        deleteButtons.forEach(btn => {
	            if (enabled) {
	                btn.disabled = false;
	            } else {
	                btn.disabled = true;
	                // Сбрасываем выделение при выходе из режима редактирования
	                const tableName = btn.getAttribute('data-table');
	                clearAllSelections(tableName);
	            }
	        });
	        
	        addButtons.forEach(btn => {
	            btn.disabled = !enabled;
	        });
	        
	        if (attachFileBtn) {
	            attachFileBtn.disabled = !enabled;
	        }
	    }
	    
	    // Функция очистки всех выделений в таблице
	    function clearAllSelections(tableName) {
	        const checkboxes = document.querySelectorAll(`.row-checkbox[data-table="${tableName}"]`);
	        const selectAllCheckbox = document.querySelector(`.select-all[data-table="${tableName}"]`);
	        
	        checkboxes.forEach(cb => cb.checked = false);
	        if (selectAllCheckbox) selectAllCheckbox.checked = false;
	        
	        // Обновляем состояние кнопки удаления
	        updateDeleteButtonState(tableName);
	    }
	    
	    // Функция обновления состояния кнопки удаления
	    function updateDeleteButtonState(tableName) {
	        const checkboxes = document.querySelectorAll(`.row-checkbox[data-table="${tableName}"]`);
	        const checkedCount = Array.from(checkboxes).filter(cb => cb.checked).length;
	        const deleteBtn = document.querySelector(`.btn-delete-selected[data-table="${tableName}"]`);
	        
	        if (deleteBtn) {
	            deleteBtn.disabled = checkedCount === 0;
	        }
	    }
	    
	    // Функция удаления выбранных записей
	    function deleteSelectedRows(tableName) {
	        const checkboxes = document.querySelectorAll(`.row-checkbox[data-table="${tableName}"]:checked`);
	        const selectedIds = Array.from(checkboxes).map(cb => cb.getAttribute('data-id'));
	        
	        if (selectedIds.length === 0) {
	            showNotification('Не выбрано ни одной записи для удаления', 'error');
	            return;
	        }
	        
	        if (confirm(`Вы уверены, что хотите удалить ${selectedIds.length} запись(ей)?`)) {
	            // Здесь будет AJAX запрос на сервер для удаления
	            console.log(`Удаление записей из таблицы ${tableName} с ID:`, selectedIds);
	            
	            // Удаляем строки из таблицы
	            checkboxes.forEach(cb => {
	                const row = cb.closest('tr');
	                row.remove();
	            });
	            
	            // Очищаем выделение
	            clearAllSelections(tableName);
	            
	            showNotification(`Удалено ${selectedIds.length} записей`, 'success');
	        }
	    }
	    
	    // Функция добавления новой записи
	    function addNewRow(tableName) {
	        // Здесь будет открытие модального окна или формы для добавления
	        console.log(`Добавление новой записи в таблицу ${tableName}`);
	        showNotification(`Функция добавления записи в таблицу будет реализована`, 'success');
	    }
	    
	    // Функция для переключения вкладок
	    function initTabs() {
	        const tabs = document.querySelectorAll('.tab-btn');
	        const contents = document.querySelectorAll('.tab-content');
	        
	        tabs.forEach(tab => {
	            tab.addEventListener('click', () => {
	                const tabId = tab.getAttribute('data-tab');
	                
	                // Убираем активный класс у всех вкладок и содержимого
	                tabs.forEach(t => t.classList.remove('active'));
	                contents.forEach(c => c.classList.remove('active'));
	                
	                // Добавляем активный класс текущей вкладке и содержимому
	                tab.classList.add('active');
	                document.getElementById(`${tabId}-tab`).classList.add('active');
	            });
	        });
	    }
	    
	    // Функция инициализации обработчиков таблиц
	    function initTableHandlers() {
	        // Обработчики для чекбоксов "Выбрать все"
	        document.querySelectorAll('.select-all').forEach(selectAll => {
	            selectAll.addEventListener('change', function() {
	                const tableName = this.getAttribute('data-table');
	                const checkboxes = document.querySelectorAll(`.row-checkbox[data-table="${tableName}"]`);
	                checkboxes.forEach(cb => cb.checked = this.checked);
	                updateDeleteButtonState(tableName);
	            });
	        });
	        
	        // Обработчики для отдельных чекбоксов
	        document.querySelectorAll('.row-checkbox').forEach(checkbox => {
	            checkbox.addEventListener('change', function() {
	                const tableName = this.getAttribute('data-table');
	                updateDeleteButtonState(tableName);
	                
	                // Обновляем состояние "Выбрать все"
	                const selectAll = document.querySelector(`.select-all[data-table="${tableName}"]`);
	                const checkboxes = document.querySelectorAll(`.row-checkbox[data-table="${tableName}"]`);
	                const allChecked = Array.from(checkboxes).every(cb => cb.checked);
	                if (selectAll) selectAll.checked = allChecked;
	            });
	        });
	        
	        // Обработчики для кнопок удаления
	        document.querySelectorAll('.btn-delete-selected').forEach(btn => {
	            btn.addEventListener('click', function() {
	                const tableName = this.getAttribute('data-table');
	                deleteSelectedRows(tableName);
	            });
	        });
	        
	        // Обработчики для кнопок добавления
	        document.querySelectorAll('.btn-add-row').forEach(btn => {
	            btn.addEventListener('click', function() {
	                const tableName = this.getAttribute('data-table');
	                addNewRow(tableName);
	            });
	        });
	    }
	    
	    // Функция для прикрепления файла
	    let currentFileInput = null;
	    
	    function attachFile(targetTab) {
	        // Создаем скрытый input для выбора файла
	        if (currentFileInput) {
	            currentFileInput.remove();
	        }
	        
	        currentFileInput = document.createElement('input');
	        currentFileInput.type = 'file';
	        currentFileInput.style.display = 'none';
	        currentFileInput.accept = '.pdf,.doc,.docx,.jpg,.png';
	        
	        currentFileInput.addEventListener('change', function(e) {
	            const file = e.target.files[0];
	            if (file) {
	                // Здесь будет AJAX запрос на сервер для загрузки файла
	                console.log(`Загрузка файла "${file.name}" во вкладку "${targetTab}"`);
	                
	                // Имитация загрузки
	                setTimeout(() => {
	                    // Добавляем файл в текущую активную таблицу
	                    addFileToTable(targetTab, file.name);
	                    showNotification(`Файл "${file.name}" успешно прикреплен к "${getTabName(targetTab)}"`, 'success');
	                }, 500);
	            }
	            currentFileInput.remove();
	            currentFileInput = null;
	        });
	        
	        document.body.appendChild(currentFileInput);
	        currentFileInput.click();
	    }
	    
	    function getTabName(tabId) {
	        const tabNames = {
	            'claim': 'Претензии'
	        };
	        return tabNames[tabId] || tabId;
	    }
	    
	    function addFileToTable(tabName, fileName) {
	        let tableId;
	        switch(tabName) {
	            case 'claim':
	                tableId = 'claim-table';
	                break;
	            default:
	                return;
	        }
	        
	        const table = document.getElementById(tableId);
	        const tbody = table.querySelector('tbody');
	        
	        // Находим первую строку или создаем новую
	        const firstRow = tbody.querySelector('tr');
	        
	        if (firstRow && firstRow.querySelector('.file-link')) {
	            // Обновляем первую строку
	            const fileCell = firstRow.querySelector('td:last-child');
	            if (fileCell && fileCell.innerHTML === '—') {
	                fileCell.innerHTML = `<a href="#" class="file-link" data-file="${fileName}">📄 ${fileName}</a>`;
	            } else {
	                // Добавляем новую строку
	                addNewFileRow(tbody, fileName);
	            }
	        } else {
	            addNewFileRow(tbody, fileName);
	        }
	    }
	    
	    function addNewFileRow(tbody, fileName) {
	        const newRow = tbody.insertRow();
	        
	        // Определяем количество колонок
	        const colCount = tbody.closest('table').querySelector('thead tr').children.length;
	        
	        for (let i = 0; i < colCount; i++) {
	            const cell = newRow.insertCell(i);
	            if (i === 0) {
	                cell.className = 'checkbox-cell';
	                const checkbox = document.createElement('input');
	                checkbox.type = 'checkbox';
	                checkbox.className = 'row-checkbox';
	                checkbox.setAttribute('data-id', Date.now());
	                checkbox.setAttribute('data-table', tbody.closest('table').id.replace('-table', ''));
	                cell.appendChild(checkbox);
	                
	                // Добавляем обработчик для нового чекбокса
	                checkbox.addEventListener('change', function() {
	                    const tableName = this.getAttribute('data-table');
	                    updateDeleteButtonState(tableName);
	                    
	                    const selectAll = document.querySelector(`.select-all[data-table="${tableName}"]`);
	                    const checkboxes = document.querySelectorAll(`.row-checkbox[data-table="${tableName}"]`);
	                    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
	                    if (selectAll) selectAll.checked = allChecked;
	                });
	            } else if (i === colCount - 1) {
	                cell.innerHTML = `<a href="#" class="file-link" data-file="${fileName}">📄 ${fileName}</a>`;
	            } else {
	                cell.innerHTML = i === 1 ? Date.now() : (i === 2 ? new Date().toLocaleDateString() : '—');
	            }
	        }
	    }
	    
	    // Функция загрузки данных
	    async function loadDebtorData() {
	        // Здесь будет AJAX запрос к серверу
	        // Для примера используем локальные данные
	        const mockData = {
	            1: { id: 1, provider: "ОС", fio: "Иванов Иван Иванович", login: "ivanov.i", status: "Активный", comments: "Важный клиент. Требуется особое внимание.", connectionType: "LTE", hasEquipment: true, totalDebt: 150000, collectedAmount: 45000, remainDebt: 105000 },
