	    // Функция показа уведомления
	    function showNotification(message, type = 'success') {
	        const notification = document.createElement('div');
	        notification.className = `notification notification-${type}`;
	        notification.textContent = message;
	        document.body.appendChild(notification);
	        
	        setTimeout(() => {
	            notification.remove();
	        }, 3000);
	    }
	    
	    // Обработчик изменения свитчера
	    function handleSwitchChange(type) {
	        currentDebtor.connectionType = type;
	        updateSwitchState(type);
	        console.log('Тип подключения изменен на:', type);
	    }
	    
	    // Переключение режимов
	    function toggleEditMode() {
	        const viewMode = document.getElementById('view-mode');
	        const editMode = document.getElementById('edit-mode');
	        const commentsTextarea = document.getElementById('comments-text');
	        const lteBtn = document.getElementById('switch-lte');
	        const ethernetBtn = document.getElementById('switch-ethernet');
	        const equipmentCheckbox = document.getElementById('equipment-checkbox');
	        
	        if (viewMode.style.display !== 'none') {
	            // Переключаем в режим редактирования
	            viewMode.style.display = 'none';
	            editMode.style.display = 'block';
	            // Делаем поле комментариев редактируемым
	            commentsTextarea.readOnly = false;
	            commentsTextarea.style.backgroundColor = 'white';
	            // Включаем кнопки свитчера
	            lteBtn.disabled = false;
	            ethernetBtn.disabled = false;
	            // Включаем чекбокс оборудования
	            if (equipmentCheckbox) {
	                equipmentCheckbox.disabled = false;
	            }
	            // Включаем кнопки управления таблицами
	            setTablesEditMode(true);
	        } else {
	            // Переключаем в режим просмотра
	            viewMode.style.display = 'block';
	            editMode.style.display = 'none';
	            // Делаем поле комментариев только для чтения
	            commentsTextarea.readOnly = true;
	            commentsTextarea.style.backgroundColor = '#f9f9f9';
	            // Отключаем кнопки свитчера в режиме просмотра
	            lteBtn.disabled = true;
	            ethernetBtn.disabled = true;
	            // Отключаем чекбокс оборудования в режиме просмотра
	            if (equipmentCheckbox) {
	                equipmentCheckbox.disabled = true;
	            }
	            // Отключаем кнопки управления таблицами
	            setTablesEditMode(false);
	        }
	    }
	    
	    // Сохранение данных
	    async function saveDebtor() {
	        const equipmentCheckbox = document.getElementById('equipment-checkbox');
	        
	        const updatedDebtor = {
	            id: currentDebtor.id,
	            provider: document.getElementById('edit-provider').value,
	            fio: document.getElementById('edit-fio').value,
	            login: document.getElementById('edit-login').value,
	            status: document.getElementById('edit-status').value,
	            comments: document.getElementById('comments-text').value,
	            connectionType: currentDebtor.connectionType,
	            hasEquipment: equipmentCheckbox ? equipmentCheckbox.checked : false,
	            totalDebt: currentDebtor.totalDebt,
	            collectedAmount: currentDebtor.collectedAmount,
	            remainDebt: currentDebtor.remainDebt
	        };
	        
	        // Здесь будет AJAX запрос на сервер для сохранения
	        console.log('Сохранение данных:', updatedDebtor);
	        
	        // Имитация сохранения
	        try {
	            // В реальном приложении здесь будет fetch или axios запрос
	            // const response = await fetch(`/api/debtors/${currentDebtor.id}`, {
	            //     method: 'PUT',
	            //     headers: { 'Content-Type': 'application/json' },
	            //     body: JSON.stringify(updatedDebtor)
	            // });
	            
	            // if (!response.ok) throw new Error('Ошибка сохранения');
	            
	            // Обновляем текущие данные
	            currentDebtor = updatedDebtor;
	            
	            // Обновляем view mode
	            document.getElementById('view-provider').textContent = currentDebtor.provider;
	            document.getElementById('view-fio').textContent = currentDebtor.fio;
	            document.getElementById('view-login').textContent = currentDebtor.login;
	            document.getElementById('view-status').innerHTML = getStatusHtml(currentDebtor.status);
	            document.getElementById('comments-text').value = currentDebtor.comments;
	            updateSwitchState(currentDebtor.connectionType);
	            
	            // Обновляем статистику
	            updateStats();
	            
	            // Обновляем состояние чекбокса в режиме просмотра
	            if (equipmentCheckbox) {
	                equipmentCheckbox.checked = currentDebtor.hasEquipment;
	            }
	            
	            // Переключаем обратно в режим просмотра
	            toggleEditMode();
	            
	            // Показываем уведомление об успехе
	            showNotification('Данные успешно сохранены!', 'success');
	        } catch (error) {
	            console.error('Ошибка:', error);
	            showNotification('Ошибка при сохранении данных!', 'error');
	        }
	    }
	    
	    // Инициализация модального окна
	    function initModal() {
	        const modal = document.getElementById('fileAttachModal');
	        const attachBtn = document.getElementById('attach-file-btn');
	        const modalBtns = document.querySelectorAll('.modal-btn');
	        
	        if (attachBtn) {
	            attachBtn.addEventListener('click', () => {
	                modal.style.display = 'block';
	            });
	        }
	        
	        modalBtns.forEach(btn => {
	            btn.addEventListener('click', () => {
	                const target = btn.getAttribute('data-target');
	                if (target) {
	                    attachFile(target);
	                    modal.style.display = 'none';
	                } else if (btn.classList.contains('modal-close')) {
	                    modal.style.display = 'none';
	                }
	            });
	        });
	        
	        window.addEventListener('click', (event) => {
	            if (event.target === modal) {
	                modal.style.display = 'none';
	            }
	        });
	    }
	    
	    // Инициализация событий
	    document.addEventListener('DOMContentLoaded', function() {
	        // Загружаем данные
	        loadDebtorData();
	        
	        // Инициализируем вкладки
	        initTabs();
	        
	        // Инициализируем обработчики таблиц
	        initTableHandlers();
	        
	        // Инициализируем модальное окно
	        initModal();
	        
	        // Назначаем обработчики
	        const editBtn = document.getElementById('edit-btn');
	        const saveBtn = document.getElementById('save-btn');
	        const cancelBtn = document.getElementById('cancel-btn');
	        const switchLte = document.getElementById('switch-lte');
	        const switchEthernet = document.getElementById('switch-ethernet');
	        
	        if (editBtn) editBtn.addEventListener('click', toggleEditMode);
	        if (saveBtn) saveBtn.addEventListener('click', saveDebtor);
	        if (cancelBtn) cancelBtn.addEventListener('click', toggleEditMode);
	        
	        // Обработчики для свитчера
	        if (switchLte) {
	            switchLte.addEventListener('click', function() {
	                handleSwitchChange('LTE');
	            });
	        }
	        
	        if (switchEthernet) {
	            switchEthernet.addEventListener('click', function() {
	                handleSwitchChange('ETHERNET');
	            });
	        }
	        
	        // Изначально отключаем кнопки свитчера и чекбокс в режиме просмотра
	        if (switchLte) switchLte.disabled = true;
	        if (switchEthernet) switchEthernet.disabled = true;
	        
	        const equipmentCheckbox = document.getElementById('equipment-checkbox');
	        if (equipmentCheckbox) equipmentCheckbox.disabled = true;
	        
	        // Добавляем обработчик изменения чекбокса (опционально)
	        if (equipmentCheckbox) {
	            equipmentCheckbox.addEventListener('change', function() {
	                currentDebtor.hasEquipment = this.checked;
	                console.log('Наличие оборудования:', this.checked);
	            });
	        }
	        
	        // Изначально отключаем кнопки таблиц
	        setTablesEditMode(false);
	    });
	</script>
